<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <staticContent>
            <remove fileExtension=".csv" />
            <mimeMap fileExtension=".WEAP" mimeType="application/weap" />
            <mimeMap fileExtension=".csv" mimeType="text/csv" />
        </staticContent>
    </system.webServer>
</configuration>
